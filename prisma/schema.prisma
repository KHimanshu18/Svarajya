generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id                      String                        @id @default(uuid())
  email                   String                        @unique
  password                String
  name                    String
  role                    AdminRole
  status                  AdminStatus                   @default(ACTIVE)
  twoFactorSecret         String?
  twoFactorEnabled        Boolean                       @default(false)
  lastLoginAt             DateTime?
  lastLoginIp             String?
  failedLoginCount        Int                           @default(0)
  lockedUntil             DateTime?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  createdBy               String?
  deletedAt               DateTime?
  inviteExpiresAt         DateTime?
  inviteToken             String?
  previousPassword        String?
  twoFactorRecoveryCodes  String?
  twoFactorOtpExpiresAt   DateTime?                     @db.Timestamp(6)
  mobile                  String?
  auditLogs               AdminAuditLog[]
  sessions                AdminSession[]
  broadcasts              Broadcast[]
  parameterHistory        CalculationParameterHistory[]
  dataAccessLogs          DataAccessLog[]
  flagChanges             FeatureFlag[]                 @relation("FlagUpdatedBy")
  moduleAccessPermissions ModuleAccessPermission[]
  moduleChanges           Module[]                      @relation("ModuleUpdatedBy")
  questionChanges         Question[]                    @relation("QuestionUpdatedBy")
  reports                 ScheduledReport[]
  supportTickets          SupportTicket[]               @relation("TicketAssignedTo")
  parameterChanges        SystemParameter[]             @relation("ParameterUpdatedBy")
  tutorialChanges         Tutorial[]                    @relation("TutorialUpdatedBy")

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("admin_users")
}

model AdminSession {
  id             String    @id @default(uuid())
  adminUserId    String
  token          String    @unique
  refreshToken   String    @unique
  ipAddress      String
  userAgent      String?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  adminUser      AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([token])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model ModuleAccessPermission {
  id          String    @id @default(uuid())
  adminUserId String
  moduleCode  String
  granted     Boolean   @default(true)
  grantedBy   String?
  grantedAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, moduleCode])
  @@index([adminUserId])
  @@map("module_access_permissions")
}

model AdminAuditLog {
  id          String      @id @default(uuid())
  adminUserId String
  actionType  AuditAction
  entityType  String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String
  userAgent   String?
  timestamp   DateTime    @default(now())
  adminUser   AdminUser   @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([entityType])
  @@index([actionType])
  @@index([timestamp])
  @@map("admin_audit_logs")
}

model DataAccessLog {
  id              String    @id @default(uuid())
  adminUserId     String
  userId          String
  actionPerformed String
  dataScope       String
  justification   String?
  ipAddress       String
  timestamp       DateTime  @default(now())
  adminUser       AdminUser @relation(fields: [adminUserId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([adminUserId])
  @@index([userId])
  @@index([timestamp])
  @@map("data_access_logs")
}

model ConsentRecord {
  id           String    @id @default(uuid())
  userId       String
  consentType  String
  consentGiven Boolean
  consentedAt  DateTime?
  revokedAt    DateTime?
  version      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType])
  @@index([userId])
  @@index([consentType])
  @@map("consent_records")
}

model SystemParameter {
  id          String     @id @default(uuid())
  key         String     @unique
  value       String
  valueType   ParamType  @default(STRING)
  description String?
  category    String?
  version     Int        @default(1)
  updatedBy   String?
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())
  admin       AdminUser? @relation("ParameterUpdatedBy", fields: [updatedBy], references: [id])

  @@index([key])
  @@index([category])
  @@map("system_parameters")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model FeatureFlag {
  id              String        @id @default(uuid())
  name            String        @unique
  description     String?
  enabled         Boolean       @default(false)
  personaScope    Json?
  cohortScope     String?
  geoScope        Json?
  startDate       DateTime?
  endDate         DateTime?
  dependsOnFlagId String?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  creator         AdminUser     @relation("FlagUpdatedBy", fields: [createdBy], references: [id])
  dependsOn       FeatureFlag?  @relation("FlagDependency", fields: [dependsOnFlagId], references: [id])
  dependents      FeatureFlag[] @relation("FlagDependency")

  @@index([name])
  @@index([enabled])
  @@map("feature_flags")
}

model Module {
  id               String               @id @default(uuid())
  code             String               @unique
  name             String
  nameHindi        String?
  zoneType         ZoneType
  iconRef          String?
  description      String?
  displayOrder     Int
  isMvp            Boolean              @default(false)
  visibilityStatus ContentStatus        @default(DRAFT)
  featureFlagId    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  updatedBy        String?
  admin            AdminUser?           @relation("ModuleUpdatedBy", fields: [updatedBy], references: [id])
  submodules       Submodule[]
  userProgress     UserModuleProgress[]

  @@index([code])
  @@index([visibilityStatus])
  @@index([isMvp])
  @@map("modules")
}

model Submodule {
  id               String                @id @default(uuid())
  moduleId         String
  code             String                @unique
  name             String
  nameHindi        String?
  adhyayaTitle     String?
  tutorialCount    Int                   @default(0)
  gameTemplateType String?
  gameCount        Int                   @default(0)
  fieldCount       Int                   @default(0)
  completionRules  Json?
  displayOrder     Int
  visibilityStatus ContentStatus         @default(DRAFT)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  questions        Question[]
  module           Module                @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tutorials        Tutorial[]
  userProgress     UserChapterProgress[]

  @@index([moduleId])
  @@index([code])
  @@map("submodules")
}

model Tutorial {
  id               String               @id @default(uuid())
  submoduleId      String
  language         String               @default("en")
  title            String
  description      String?
  youtubeUrl       String?
  youtubeId        String?
  durationSeconds  Int?
  transcriptText   String?
  mustWatch        Boolean              @default(false)
  visibilityStatus ContentStatus        @default(DRAFT)
  personaScope     Json?
  cohortScope      String?
  publishStartDate DateTime?
  publishEndDate   DateTime?
  displayOrder     Int
  version          Int                  @default(1)
  changeNotes      String?
  createdBy        String
  updatedBy        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  analytics        TutorialAnalytics[]
  completions      TutorialCompletion[]
  creator          AdminUser            @relation("TutorialUpdatedBy", fields: [createdBy], references: [id])
  submodule        Submodule            @relation(fields: [submoduleId], references: [id], onDelete: Cascade)

  @@index([submoduleId])
  @@index([language])
  @@index([visibilityStatus])
  @@map("tutorials")
}

model TutorialCompletion {
  id            String   @id @default(uuid())
  userId        String
  tutorialId    String
  watchedAt     DateTime @default(now())
  watchDuration Int?
  completed     Boolean  @default(false)
  tutorial      Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorialId])
  @@index([userId])
  @@index([tutorialId])
  @@map("tutorial_completions")
}

model TutorialAnalytics {
  id               String   @id @default(uuid())
  tutorialId       String
  date             DateTime @default(now()) @db.Date
  startedCount     Int      @default(0)
  completedCount   Int      @default(0)
  avgWatchDuration Float?
  dropOffPoint     Int?
  tutorial         Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@unique([tutorialId, date])
  @@index([tutorialId])
  @@index([date])
  @@map("tutorial_analytics")
}

model Question {
  id               String        @id @default(uuid())
  submoduleId      String
  questionType     QuestionType
  questionText     String
  explanationText  String?
  language         String        @default("en")
  fieldMappingId   String?
  scoringWeight    Int           @default(1)
  required         Boolean       @default(true)
  personaScope     Json?
  visibilityStatus ContentStatus @default(DRAFT)
  displayOrder     Int
  version          Int           @default(1)
  createdBy        String
  updatedBy        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  creator          AdminUser     @relation("QuestionUpdatedBy", fields: [createdBy], references: [id])
  fieldMapping     FieldMapping? @relation(fields: [fieldMappingId], references: [id])
  submodule        Submodule     @relation(fields: [submoduleId], references: [id], onDelete: Cascade)
  answers          QuizAnswer[]

  @@index([submoduleId])
  @@index([questionType])
  @@index([visibilityStatus])
  @@map("questions")
}

model FieldMapping {
  id              String     @id @default(uuid())
  databaseTable   String
  databaseField   String
  validationRule  Json?
  calculationDeps Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  questions       Question[]

  @@unique([databaseTable, databaseField])
  @@index([databaseTable])
  @@map("field_mappings")
}

model QuizAnswer {
  id            String   @id @default(uuid())
  userId        String
  questionId    String
  answerValue   Json
  attemptNumber Int      @default(1)
  answeredAt    DateTime @default(now())
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@map("quiz_answers")
}

model CalculationParameter {
  id           String                        @id @default(uuid())
  key          String                        @unique
  value        Float
  defaultValue Float
  description  String?
  category     String?
  version      Int                           @default(1)
  updatedAt    DateTime                      @updatedAt
  createdAt    DateTime                      @default(now())
  history      CalculationParameterHistory[]

  @@index([key])
  @@index([category])
  @@map("calculation_parameters")
}

model CalculationParameterHistory {
  id           String               @id @default(uuid())
  parameterId  String
  parameterKey String
  oldValue     Float
  newValue     Float
  changedBy    String
  reason       String?
  changedAt    DateTime             @default(now())
  admin        AdminUser            @relation(fields: [changedBy], references: [id])
  parameter    CalculationParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@index([parameterId])
  @@index([parameterKey])
  @@index([changedAt])
  @@map("calculation_parameter_history")
}

model NotificationTemplate {
  id               String         @id @default(uuid())
  name             String         @unique
  channel          NotifChannel
  language         String         @default("en")
  subject          String?
  bodyTemplate     String
  triggerEvent     String
  personaScope     Json?
  visibilityStatus ContentStatus  @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  notifications    Notification[]

  @@index([name])
  @@index([channel])
  @@index([triggerEvent])
  @@map("notification_templates")
}

model Notification {
  id          String                @id @default(uuid())
  userId      String
  templateId  String?
  channel     NotifChannel
  subject     String?
  body        String
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  status      NotifStatus           @default(PENDING)
  createdAt   DateTime              @default(now())
  link        String?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id])
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model Broadcast {
  id             String          @id @default(uuid())
  createdBy      String
  title          String
  body           String
  ctaText        String?
  ctaUrl         String?
  targetScope    Json
  channel        NotifChannel
  scheduledFor   DateTime?
  expiresAt      DateTime?
  sentAt         DateTime?
  status         BroadcastStatus @default(DRAFT)
  sentCount      Int             @default(0)
  deliveredCount Int             @default(0)
  openedCount    Int             @default(0)
  clickedCount   Int             @default(0)
  createdAt      DateTime        @default(now())
  admin          AdminUser       @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([scheduledFor])
  @@map("broadcasts")
}

model Cohort {
  id               String       @id @default(uuid())
  name             String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  assignedModules  Json
  weeklyTasks      Json?
  announcementText String?
  visibilityFlag   Boolean      @default(true)
  maxCapacity      Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  members          UserCohort[]

  @@index([name])
  @@map("cohorts")
}

model UserCohort {
  id       String    @id @default(uuid())
  userId   String
  cohortId String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  cohort   Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cohortId])
  @@index([userId])
  @@index([cohortId])
  @@map("user_cohorts")
}

model IKSAsset {
  id             String    @id @default(uuid())
  assetType      AssetType
  fileUrl        String
  fileName       String
  moduleScope    String?
  language       String?
  version        Int       @default(1)
  visibilityFlag Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([assetType])
  @@index([moduleScope])
  @@map("iks_assets")
}

model SupportTicket {
  id               String           @id @default(uuid())
  userId           String
  category         TicketCategory
  subject          String
  description      String
  status           TicketStatus     @default(OPEN)
  priority         TicketPriority   @default(MEDIUM)
  assignedTo       String?
  deviceInfo       Json?
  appVersion       String?
  screenshots      Json?
  internalNotes    String?
  resolvedAt       DateTime?
  userSatisfaction Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignedAdmin    AdminUser?       @relation("TicketAssignedTo", fields: [assignedTo], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses        TicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@map("support_tickets")
}

model TicketResponse {
  id            String        @id @default(uuid())
  ticketId      String
  responderId   String?
  responderType String
  message       String
  isInternal    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}

model UserFeedback {
  id           String       @id @default(uuid())
  userId       String
  feedbackType FeedbackType
  entityType   String?
  entityId     String?
  rating       Int?
  sentiment    String?
  comment      String?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feedbackType])
  @@index([entityType])
  @@map("user_feedback")
}

model FAQ {
  id              String   @id @default(uuid())
  category        String
  question        String
  answer          String
  language        String   @default("en")
  displayOrder    Int
  linkedEntity    String?
  viewCount       Int      @default(0)
  helpfulCount    Int      @default(0)
  notHelpfulCount Int      @default(0)
  visibilityFlag  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([language])
  @@map("faqs")
}

model ScheduledReport {
  id         String          @id @default(uuid())
  createdBy  String
  reportType ReportType
  frequency  ReportFrequency
  recipients Json
  format     String          @default("PDF")
  lastRunAt  DateTime?
  nextRunAt  DateTime
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  admin      AdminUser       @relation(fields: [createdBy], references: [id])

  @@index([nextRunAt])
  @@map("scheduled_reports")
}

model User {
  id                     String                @id @default(uuid())
  email                  String?               @unique
  phone                  String?               @unique
  passwordHash           String?
  name                   String?
  dob                    DateTime?             @db.Date
  gender                 String?
  panMasked              String?
  aadhaarMasked          String?
  primaryMobile          String?
  primaryEmail           String?
  recoveryEmail          String?
  address                String?
  maritalStatus          String?
  occupationType         String?
  employerCompany        String?
  profileType            ProfileType
  status                 UserStatus            @default(ACTIVE)
  language               String                @default("en")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  lastActiveAt           DateTime?
  deviceInfo             Json?
  googleAccessToken      String?
  googleLinked           Boolean               @default(false)
  googleRefreshToken     String?
  googleTokenExpiry      DateTime?
  is_first_login         Boolean               @default(true)
  secondaryMobile        String?
  settings               Json?
  twoFactorRecoveryCodes String?
  twoFactorSecret        String?
  authProvider           String?               @default("EMAIL")
  activityEvents         ActivityEvent[]
  assetInventory         AssetInventory[]
  bankAccounts           BankAccount[]
  budgetPlans            BudgetPlan[]
  cashWallet             CashWallet?
  consentRecords         ConsentRecord[]
  credentials            CredentialRecord[]
  dataAccessLogs         DataAccessLog[]
  documentMeta           DocumentMeta[]
  education              Education[]
  expenseCategories      ExpenseCategory[]
  expenses               ExpenseEntry[]
  familyMembers          FamilyMember[]
  gameRuns               GameRun[]
  gamificationState      GamificationState?
  goals                  Goal[]
  identityLinks          IdentityLink[]
  identityRecords        IdentityRecord[]
  incomeStreams          IncomeStream[]
  insurancePolicies      InsurancePolicy[]
  investments            InvestmentHolding[]
  loans                  LoanAccount[]
  nomineeMapping         NomineeMapping[]
  notifications          Notification[]
  properties             PropertyAsset[]
  taxRecords             TaxRecord[]
  gstRecords             GstRecord[]
  dinRecords             DinRecord[]
  quizAnswers            QuizAnswer[]
  rajyaScore             RajyaScore?
  reminders              Reminder[]
  subscriptions          Subscription[]
  supportTickets         SupportTicket[]
  tutorialCompletion     TutorialCompletion[]
  chapterProgress        UserChapterProgress[]
  cohorts                UserCohort[]
  feedback               UserFeedback[]
  moduleProgress         UserModuleProgress[]
  sessions               UserSession[]
  willStatus             WillStatus?

  @@index([email])
  @@index([phone])
  @@index([profileType])
  @@index([status])
  @@map("users")
}

model UserSession {
  id             String   @id @default(uuid())
  userId         String
  token          String   @unique
  refreshToken   String   @unique
  deviceType     String?
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

model FamilyMember {
  id              String              @id @default(uuid())
  userId          String
  name            String
  relation        String
  dob             DateTime?           @db.Date
  isDependent     Boolean             @default(false)
  nomineeEligible Boolean             @default(true)
  accessLevel     String              @default("VIEW")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  education       Education[]
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeStreams   IncomeStream[]
  coveredBy       InsuranceCoverage[]
  nomineeIn       NomineeMapping[]

  @@index([userId])
  @@map("family_members")
}

model Education {
  id             String        @id @default(uuid())
  userId         String
  degree         String
  institute      String
  yearCompleted  Int?
  specialization String?
  linkedLoanId   String?
  createdAt      DateTime      @default(now())
  certificateUrl String?
  familyMemberId String?
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("education")
}

model IdentityRecord {
  id             String         @id @default(uuid())
  userId         String
  idType         String
  numberMasked   String
  numberFull     String?
  expiryDate     DateTime?      @db.Date
  issuedDate     DateTime?      @db.Date
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  dobOnDoc       DateTime?      @db.Date
  nameOnDoc      String?
  placeOfIssue   String?
  vaultFileId    String?
  familyMemberId String?
  links          IdentityLink[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idType])
  @@unique([userId, idType, familyMemberId], map: "identity_records_userid_idtype_familymemberid_key")
  @@index([userId])
  @@map("identity_records")
}

model IdentityLink {
  id          String         @id @default(uuid())
  userId      String
  identityId  String
  linkedType  String
  linkedValue String
  serviceName String?
  createdAt   DateTime       @default(now())
  identity    IdentityRecord @relation(fields: [identityId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([identityId])
  @@map("identity_links")
}

model CredentialRecord {
  id                String    @id @default(uuid())
  userId            String
  portalType        String
  portalName        String
  portalUrl         String?
  loginId           String?
  registeredEmail   String?
  registeredMobile  String?
  storageMode       String    @default("REFERENCE")
  encryptedPassword String?
  linkedMemberId    String?
  registrationDate  DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  nomineeAwareness  Boolean?  @default(true)
  twoFAStatus       String?   @default("unknown")
  twoFAType         String?   @default("none")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([portalType])
  @@map("credential_records")
}

model IncomeStream {
  id                String        @id @default(uuid())
  userId            String
  type              String
  source            String?
  frequency         String        @default("MONTHLY")
  amountGross       Float
  deductions        Float         @default(0)
  amountNet         Float
  creditedAccountId String?
  isPrimary         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  allocationMonths  Int?
  description       String?
  expectedGrowthPct Int?
  historicalIncome  Json?
  notes             String?
  riskLevel         String?
  tdsAmount         Float?
  familyMemberId    String?
  lastReviewedAt    DateTime?
  familyMember      FamilyMember? @relation(fields: [familyMemberId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("income_streams")
}

model ExpenseEntry {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @default(now()) @db.Date
  amount      Float
  category    String
  mode        String?
  accountId   String?
  description String?
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  frequency   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("expense_entries")
}

