// ============================================================================
// PRISMA SCHEMA — LIFE BALANCE + SVARAJYA CENTRAL ROOM
// ============================================================================
// Database: PostgreSQL
// ORM: Prisma
// Version: 1.0.0
// Last Updated: 2025
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// SECTION 1: ADMIN PORTAL (SVARAJYA CENTRAL ROOM)
// ============================================================================

// ----------------------------------------------------------------------------
// Admin Users & Authentication
// ----------------------------------------------------------------------------

model AdminUser {
  id                String              @id @default(uuid())
  email             String              @unique
  password          String // bcrypt hashed
  name              String
  role              AdminRole
  status            AdminStatus         @default(ACTIVE)
  twoFactorSecret   String? // TOTP secret for 2FA
  twoFactorEnabled  Boolean             @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  failedLoginCount  Int                 @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String?

  // Relations
  sessions          AdminSession[]
  auditLogs         AdminAuditLog[]
  dataAccessLogs    DataAccessLog[]
  moduleChanges     Module[]            @relation("ModuleUpdatedBy")
  parameterChanges  SystemParameter[]   @relation("ParameterUpdatedBy")
  flagChanges       FeatureFlag[]       @relation("FlagUpdatedBy")
  tutorialChanges   Tutorial[]          @relation("TutorialUpdatedBy")
  questionChanges   Question[]          @relation("QuestionUpdatedBy")
  supportTickets    SupportTicket[]     @relation("TicketAssignedTo")
  broadcasts        Broadcast[]
  reports           ScheduledReport[]
  parameterHistory  CalculationParameterHistory[] 

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_ADMIN
  QUIZ_ADMIN
  COMPLIANCE_ADMIN
  COHORT_ADMIN
  SUPPORT_ADMIN
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_INVITE
}

model AdminSession {
  id            String    @id @default(uuid())
  adminUserId   String
  token         String    @unique
  refreshToken  String    @unique
  ipAddress     String
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  lastActivityAt DateTime @default(now())

  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([token])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// ----------------------------------------------------------------------------
// Audit & Compliance
// ----------------------------------------------------------------------------

model AdminAuditLog {
  id            String      @id @default(uuid())
  adminUserId   String
  actionType    AuditAction
  entityType    String // "module", "question", "feature_flag", "user_account", etc.
  entityId      String?
  oldValue      Json? // Store before state
  newValue      Json? // Store after state
  ipAddress     String
  userAgent     String?
  timestamp     DateTime    @default(now())

  adminUser     AdminUser   @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([entityType])
  @@index([actionType])
  @@index([timestamp])
  @@map("admin_audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  ROLLBACK
  EXPORT
  RESET
  LOGIN
  LOGIN_FAIL
  LOGOUT
  FORCE_LOGOUT
  VIEW
  TOGGLE
}

model DataAccessLog {
  id              String    @id @default(uuid())
  adminUserId     String
  userId          String // User whose data was accessed
  actionPerformed String // "viewed_progress", "reset_module", "exported_data", "suspended_account"
  dataScope       String // "progress_only", "full_export", "account_action"
  justification   String? // Admin must provide reason
  ipAddress       String
  timestamp       DateTime  @default(now())

  adminUser       AdminUser @relation(fields: [adminUserId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([adminUserId])
  @@index([userId])
  @@index([timestamp])
  @@map("data_access_logs")
}

model ConsentRecord {
  id                String    @id @default(uuid())
  userId            String
  consentType       String // "cloud_backup", "ai_advisor", "whatsapp_notifications", "terms_v1.2"
  consentGiven      Boolean
  consentedAt       DateTime?
  revokedAt         DateTime?
  version           String? // e.g., "v1.2" for terms
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType])
  @@index([userId])
  @@index([consentType])
  @@map("consent_records")
}

// ----------------------------------------------------------------------------
// System Configuration
// ----------------------------------------------------------------------------

model SystemParameter {
  id            String    @id @default(uuid())
  key           String    @unique
  value         String
  valueType     ParamType @default(STRING)
  description   String?
  category      String? // "security", "financial", "general"
  version       Int       @default(1)
  updatedBy     String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  admin         AdminUser? @relation("ParameterUpdatedBy", fields: [updatedBy], references: [id])

  @@index([key])
  @@index([category])
  @@map("system_parameters")
}

enum ParamType {
  STRING
  INTEGER
  FLOAT
  BOOLEAN
  JSON
}

model SystemSetting {
  id                  String    @id @default(uuid())
  key                 String    @unique
  value               String
  description         String?
  updatedAt           DateTime  @updatedAt

  @@map("system_settings")
}

// ----------------------------------------------------------------------------
// Feature Flags
// ----------------------------------------------------------------------------

model FeatureFlag {
  id              String      @id @default(uuid())
  name            String      @unique
  description     String?
  enabled         Boolean     @default(false)
  personaScope    Json? // ["INDIVIDUAL_SALARIED", "FAMILY"] or null for all
  cohortScope     String? // Cohort ID or null for all
  geoScope        Json? // ["MH", "DL"] state codes or null for all
  startDate       DateTime?
  endDate         DateTime?
  dependsOnFlagId String? // Another flag that must be enabled first
  createdBy       String
  updatedBy       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  creator         AdminUser   @relation("FlagUpdatedBy", fields: [createdBy], references: [id])
  dependsOn       FeatureFlag? @relation("FlagDependency", fields: [dependsOnFlagId], references: [id])
  dependents      FeatureFlag[] @relation("FlagDependency")

  @@index([name])
  @@index([enabled])
  @@map("feature_flags")
}

// ----------------------------------------------------------------------------
// Modules & Submodules (Registry)
// ----------------------------------------------------------------------------

model Module {
  id                String      @id @default(uuid())
  code              String      @unique // M01, M02, etc.
  name              String
  nameHindi         String?
  zoneType          ZoneType
  iconRef           String?
  description       String?
  displayOrder      Int
  isMvp             Boolean     @default(false)
  visibilityStatus  ContentStatus @default(DRAFT)
  featureFlagId     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  updatedBy         String?

  admin             AdminUser?  @relation("ModuleUpdatedBy", fields: [updatedBy], references: [id])
  submodules        Submodule[]
  userProgress      UserModuleProgress[]

  @@index([code])
  @@index([visibilityStatus])
  @@index([isMvp])
  @@map("modules")
}

enum ZoneType {
  RAKSHA // Insurance
  KOSH // Income/Wealth
  VYAYA // Expenses
  RIN // Loans
  DURG // Emergency
  MITRA // Nominee/Legacy
  BHOOMI // Property
  GRANTHAGAAR // Documents
  KAR // Tax
  OTHER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  HIDDEN
}

model Submodule {
  id                String      @id @default(uuid())
  moduleId          String
  code              String      @unique // M01.S01, M01.S02, etc.
  name              String
  nameHindi         String?
  adhyayaTitle      String?
  tutorialCount     Int         @default(0)
  gameTemplateType  String? // "FORT_DEFENSE", "MANDALA_LINK", etc.
  gameCount         Int         @default(0)
  fieldCount        Int         @default(0)
  completionRules   Json? // Store as JSON
  displayOrder      Int
  visibilityStatus  ContentStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  module            Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tutorials         Tutorial[]
  questions         Question[]
  userProgress      UserChapterProgress[]

  @@index([moduleId])
  @@index([code])
  @@map("submodules")
}

// ----------------------------------------------------------------------------
// Content: Tutorials
// ----------------------------------------------------------------------------

model Tutorial {
  id                String      @id @default(uuid())
  submoduleId       String
  language          String      @default("en") // "en", "hi"
  title             String
  description       String?
  youtubeUrl        String?
  youtubeId         String?
  durationSeconds   Int?
  transcriptText    String?
  mustWatch         Boolean     @default(false)
  visibilityStatus  ContentStatus @default(DRAFT)
  personaScope      Json? // null = all
  cohortScope       String?
  publishStartDate  DateTime?
  publishEndDate    DateTime?
  displayOrder      Int
  version           Int         @default(1)
  changeNotes       String?
  createdBy         String
  updatedBy         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  submodule         Submodule   @relation(fields: [submoduleId], references: [id], onDelete: Cascade)
  creator           AdminUser   @relation("TutorialUpdatedBy", fields: [createdBy], references: [id])
  completions       TutorialCompletion[]
  analytics         TutorialAnalytics[]

  @@index([submoduleId])
  @@index([language])
  @@index([visibilityStatus])
  @@map("tutorials")
}

model TutorialCompletion {
  id              String    @id @default(uuid())
  userId          String
  tutorialId      String
  watchedAt       DateTime  @default(now())
  watchDuration   Int? // seconds watched
  completed       Boolean   @default(false)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorial        Tutorial  @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorialId])
  @@index([userId])
  @@index([tutorialId])
  @@map("tutorial_completions")
}

model TutorialAnalytics {
  id                String    @id @default(uuid())
  tutorialId        String
  date              DateTime  @default(now()) @db.Date
  startedCount      Int       @default(0)
  completedCount    Int       @default(0)
  avgWatchDuration  Float?
  dropOffPoint      Int? // seconds where most users stop

  tutorial          Tutorial  @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@unique([tutorialId, date])
  @@index([tutorialId])
  @@index([date])
  @@map("tutorial_analytics")
}

// ----------------------------------------------------------------------------
// Content: Quiz & Questions
// ----------------------------------------------------------------------------

model Question {
  id                String      @id @default(uuid())
  submoduleId       String
  questionType      QuestionType
  questionText      String
  explanationText   String?
  language          String      @default("en")
  fieldMappingId    String?
  scoringWeight     Int         @default(1)
  required          Boolean     @default(true)
  personaScope      Json?
  visibilityStatus  ContentStatus @default(DRAFT)
  displayOrder      Int
  version           Int         @default(1)
  createdBy         String
  updatedBy         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  submodule         Submodule   @relation(fields: [submoduleId], references: [id], onDelete: Cascade)
  creator           AdminUser   @relation("QuestionUpdatedBy", fields: [createdBy], references: [id])
  fieldMapping      FieldMapping? @relation(fields: [fieldMappingId], references: [id])
  answers           QuizAnswer[]

  @@index([submoduleId])
  @@index([questionType])
  @@index([visibilityStatus])
  @@map("questions")
}

enum QuestionType {
  MCQ
  NUMERIC
  BOOLEAN
  MULTI_SELECT
  DATE
  PHONE
  EMAIL
  SLIDER
  CONFIRM
  TEXT
}

model FieldMapping {
  id                String      @id @default(uuid())
  databaseTable     String // "incomeStream", "insurancePolicy", etc.
  databaseField     String // "gross", "premium", etc.
  validationRule    Json? // regex, min, max, format
  calculationDeps   Json? // Which calculations use this field
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  questions         Question[]

  @@unique([databaseTable, databaseField])
  @@index([databaseTable])
  @@map("field_mappings")
}

model QuizAnswer {
  id              String    @id @default(uuid())
  userId          String
  questionId      String
  answerValue     Json // Stores answer in appropriate format
  attemptNumber   Int       @default(1)
  answeredAt      DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@map("quiz_answers")
}

// ----------------------------------------------------------------------------
// Financial Calculation Parameters
// ----------------------------------------------------------------------------

model CalculationParameter {
  id              String    @id @default(uuid())
  key             String    @unique // "emi_burden_threshold", "raksha_weight", etc.
  value           Float
  defaultValue    Float
  description     String?
  category        String? // "threshold", "weight"
  version         Int       @default(1)
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
   history         CalculationParameterHistory[]

  @@index([key])
  @@index([category])
  @@map("calculation_parameters")
}

model CalculationParameterHistory {
  id           String   @id @default(uuid())
  parameterId  String
  parameterKey String // Denormalized for easy querying
  oldValue     Float
  newValue     Float
  changedBy    String
  reason       String?
  changedAt    DateTime @default(now())

  parameter CalculationParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)
  admin     AdminUser            @relation(fields: [changedBy], references: [id])

  @@index([parameterId])
  @@index([parameterKey])
  @@index([changedAt])
  @@map("calculation_parameter_history")
}

// ----------------------------------------------------------------------------
// Notifications & Alerts
// ----------------------------------------------------------------------------

model NotificationTemplate {
  id                String      @id @default(uuid())
  name              String      @unique
  channel           NotifChannel
  language          String      @default("en")
  subject           String?
  bodyTemplate      String // Can include variables like {user_name}, {due_date}
  triggerEvent      String // "insurance_renewal_due", "module_completed", etc.
  personaScope      Json?
  visibilityStatus  ContentStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  notifications     Notification[]

  @@index([name])
  @@index([channel])
  @@index([triggerEvent])
  @@map("notification_templates")
}

enum NotifChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
}

model Notification {
  id              String      @id @default(uuid())
  userId          String
  templateId      String?
  channel         NotifChannel
  subject         String?
  body            String
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  status          NotifStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

enum NotifStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
}

model Broadcast {
  id              String      @id @default(uuid())
  createdBy       String
  title           String
  body            String
  ctaText         String?
  ctaUrl          String?
  targetScope     Json // {persona: [], cohort: [], engagementSegment: []}
  channel         NotifChannel
  scheduledFor    DateTime?
  expiresAt       DateTime?
  sentAt          DateTime?
  status          BroadcastStatus @default(DRAFT)
  sentCount       Int         @default(0)
  deliveredCount  Int         @default(0)
  openedCount     Int         @default(0)
  clickedCount    Int         @default(0)
  createdAt       DateTime    @default(now())

  admin           AdminUser   @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([scheduledFor])
  @@map("broadcasts")
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// ----------------------------------------------------------------------------
// Cohorts
// ----------------------------------------------------------------------------

model Cohort {
  id                String      @id @default(uuid())
  name              String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  assignedModules   Json // Array of module codes
  weeklyTasks       Json?
  announcementText  String?
  visibilityFlag    Boolean     @default(true)
  maxCapacity       Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  members           UserCohort[]

  @@index([name])
  @@map("cohorts")
}

model UserCohort {
  id              String    @id @default(uuid())
  userId          String
  cohortId        String
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort          Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@unique([userId, cohortId])
  @@index([userId])
  @@index([cohortId])
  @@map("user_cohorts")
}

// ----------------------------------------------------------------------------
// IKS (Visual Assets)
// ----------------------------------------------------------------------------

model IKSAsset {
  id              String      @id @default(uuid())
  assetType       AssetType
  fileUrl         String
  fileName        String
  moduleScope     String? // Module code or null for global
  language        String?
  version         Int         @default(1)
  visibilityFlag  Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([assetType])
  @@index([moduleScope])
   
  @@map("iks_assets")
}

enum AssetType {
  ICON
  STORY_CARD
  MAP_ELEMENT
  ANIMATION
  SOUND
}

// ----------------------------------------------------------------------------
// Support & Feedback
// ----------------------------------------------------------------------------

model SupportTicket {
  id              String        @id @default(uuid())
  userId          String
  category        TicketCategory
  subject         String
  description     String
  status          TicketStatus  @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  assignedTo      String?
  deviceInfo      Json?
  appVersion      String?
  screenshots     Json? // Array of URLs
  internalNotes   String?
  resolvedAt      DateTime?
  userSatisfaction Int? // 1-5 rating
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin   AdminUser?    @relation("TicketAssignedTo", fields: [assignedTo], references: [id])
  responses       TicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@map("support_tickets")
}

enum TicketCategory {
  BUG
  QUESTION
  SUGGESTION
  ACCOUNT_ISSUE
  DATA_CONCERN
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TicketResponse {
  id              String      @id @default(uuid())
  ticketId        String
  responderId     String? // Can be admin or user
  responderType   String // "admin" or "user"
  message         String
  isInternal      Boolean     @default(false) // Internal admin notes
  createdAt       DateTime    @default(now())

  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}

model UserFeedback {
  id              String      @id @default(uuid())
  userId          String
  feedbackType    FeedbackType
  entityType      String? // "chapter", "module", "game"
  entityId        String?
  rating          Int? // 1-5 stars
  sentiment       String? // "positive", "neutral", "negative"
  comment         String?
  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feedbackType])
  @@index([entityType])
  @@map("user_feedback")
}

enum FeedbackType {
  CHAPTER_RATING
  MODULE_RATING
  GAME_RATING
  NPS_SURVEY
  GENERAL_FEEDBACK
  FEATURE_REQUEST
}

model FAQ {
  id              String      @id @default(uuid())
  category        String
  question        String
  answer          String
  language        String      @default("en")
  displayOrder    Int
  linkedEntity    String? // "M08.S02" or "tutorial_xyz"
  viewCount       Int         @default(0)
  helpfulCount    Int         @default(0)
  notHelpfulCount Int         @default(0)
  visibilityFlag  Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([category])
  @@index([language])
  @@map("faqs")
}

// ----------------------------------------------------------------------------
// Reports
// ----------------------------------------------------------------------------

model ScheduledReport {
  id              String      @id @default(uuid())
  createdBy       String
  reportType      ReportType
  frequency       ReportFrequency
  recipients      Json // Array of email addresses
  format          String      @default("PDF") // "PDF", "CSV"
  lastRunAt       DateTime?
  nextRunAt       DateTime
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  admin           AdminUser   @relation(fields: [createdBy], references: [id])

  @@index([nextRunAt])
  @@map("scheduled_reports")
}

enum ReportType {
  DAILY_SUMMARY
  WEEKLY_ENGAGEMENT
  MONTHLY_HEALTH
  CUSTOM
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================================================
// SECTION 2: USER APP (LIFE BALANCE)
// ============================================================================

// ----------------------------------------------------------------------------
// Users & Authentication
// ----------------------------------------------------------------------------

model User {
  id                String      @id @default(uuid())
  email             String?     @unique
  phone             String?     @unique
  passwordHash      String?
  name              String?
  dob               DateTime?   @db.Date
  gender            String?
  panMasked         String?
  aadhaarMasked     String?
  primaryMobile     String?
  primaryEmail      String?
  recoveryEmail     String?
  address           String?
  maritalStatus     String?
  occupationType    String? // "SALARIED", "SELF_EMPLOYED", "PROFESSIONAL"
  employerCompany   String?
  profileType       ProfileType
  status            UserStatus  @default(ACTIVE)
  language          String      @default("en")
  is_first_login    Boolean     @default(true)
  googleLinked      Boolean     @default(false)
  googleRefreshToken String?
  googleAccessToken  String?
  googleTokenExpiry  DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  lastActiveAt      DateTime?
  deviceInfo        Json?
  settings  Json?

  // Relations
  sessions          UserSession[]
  familyMembers     FamilyMember[]
  education         Education[]
  identityRecords   IdentityRecord[]
  identityLinks     IdentityLink[]
  credentials       CredentialRecord[]
  incomeStreams     IncomeStream[]
  expenses          ExpenseEntry[]
  budgetPlans       BudgetPlan[]
  bankAccounts      BankAccount[]
  investments       InvestmentHolding[]
  insurancePolicies InsurancePolicy[]
  loans             LoanAccount[]
  properties        PropertyAsset[]
  subscriptions     Subscription[]
  goals             Goal[]
  nomineeMapping    NomineeMapping[]
  willStatus        WillStatus?
  assetInventory    AssetInventory[]
  documentMeta      DocumentMeta[]
  reminders         Reminder[]
  chapterProgress   UserChapterProgress[]
  moduleProgress    UserModuleProgress[]
  gameRuns          GameRun[]
  gamificationState GamificationState?
  tutorialCompletion TutorialCompletion[]
  quizAnswers       QuizAnswer[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  feedback          UserFeedback[]
  activityEvents    ActivityEvent[]
  dataAccessLogs    DataAccessLog[]
  consentRecords    ConsentRecord[]
  cohorts           UserCohort[]
  rajyaScore        RajyaScore?

  @@index([email])
  @@index([phone])
  @@index([profileType])
  @@index([status])
  @@map("users")
}

enum ProfileType {
  INDIVIDUAL_SALARIED
  INDIVIDUAL_SELF_EMPLOYED
  FAMILY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
  PENDING_VERIFICATION
}

model UserSession {
  id              String    @id @default(uuid())
  userId          String
  token           String    @unique
  refreshToken    String    @unique
  deviceType      String? // "mobile", "desktop", "tablet"
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  lastActivityAt  DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ----------------------------------------------------------------------------
// Family Management
// ----------------------------------------------------------------------------

model FamilyMember {
  id              String    @id @default(uuid())
  userId          String // Family head
  name            String
  relation        String // "spouse", "child", "parent", etc.
  dob             DateTime? @db.Date
  isDependent     Boolean   @default(false)
  nomineeEligible Boolean   @default(true)
  accessLevel     String    @default("VIEW") // "VIEW", "EDIT", "HIDDEN"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomineeIn       NomineeMapping[]
  coveredBy       InsuranceCoverage[]
  education       Education[]

  @@index([userId])
  @@map("family_members")
}

model Education {
  id              String    @id @default(uuid())
  userId          String
  degree          String
  institute       String
  yearCompleted   Int?
  specialization  String?
  linkedLoanId    String? // If education loan exists
  certificateUrl  String?
  familyMemberId  String? // null = self (Adhipati), otherwise links to a family member
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyMember    FamilyMember? @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("education")
}

// ----------------------------------------------------------------------------
// Digital Identity & KYC
// ----------------------------------------------------------------------------

model IdentityRecord {
  id              String    @id @default(uuid())
  userId          String
  idType          String // "PAN", "AADHAAR", "PASSPORT", "DL", "VOTER_ID"
  numberMasked    String // Last 4 digits only
  numberFull      String? // Encrypted full number (optional)
  expiryDate      DateTime? @db.Date
  issuedDate      DateTime? @db.Date
  placeOfIssue    String?
  dobOnDoc        DateTime? @db.Date
  nameOnDoc       String?
  vaultFileId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  links           IdentityLink[]

  @@unique([userId, idType])
  @@index([userId])
  @@map("identity_records")
}

model IdentityLink {
  id              String    @id @default(uuid())
  userId          String
  identityId      String
  linkedType      String // "mobile", "email", "bank", "investment"
  linkedValue     String // Phone/email/account number
  serviceName     String? // "HDFC Bank", "Zerodha", etc.
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity        IdentityRecord @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([identityId])
  @@map("identity_links")
}

// ----------------------------------------------------------------------------
// Credential Vault
// ----------------------------------------------------------------------------

model CredentialRecord {
  id              String    @id @default(uuid())
  userId          String
  portalType      String // "bank", "investment", "insurance", "gov", "other"
  portalName      String
  portalUrl       String?
  loginId         String?
  registeredEmail String?
  registeredMobile String?
  storageMode     String    @default("REFERENCE") // "REFERENCE", "ENCRYPTED"
  encryptedPassword String? // Only if user chooses encrypted storage
  linkedMemberId  String? // Family member ID if applicable
  registrationDate DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([portalType])
  @@map("credential_records")
}

// ----------------------------------------------------------------------------
// Income Management
// ----------------------------------------------------------------------------

model IncomeStream {
  id              String    @id @default(uuid())
  userId          String
  type            String // "SALARY", "RENTAL", "FREELANCE", "INTEREST", "BUSINESS", "OTHER"
  source          String?
  frequency       String    @default("MONTHLY") // "MONTHLY", "QUARTERLY", "ANNUAL"
  amountGross     Float
  deductions      Float     @default(0)
  amountNet       Float
  creditedAccountId String? // BankAccount ID
  isPrimary       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("income_streams")
}

// ----------------------------------------------------------------------------
// Expense Management
// ----------------------------------------------------------------------------

model ExpenseEntry {
  id              String    @id @default(uuid())
  userId          String
  date            DateTime  @default(now()) @db.Date
  amount          Float
  category        String // "FOOD", "TRANSPORT", "HOUSING", "UTILITIES", etc.
  mode            String? // "CASH", "CARD", "UPI", "BANK_TRANSFER"
  accountId       String? // BankAccount ID if applicable
  description     String?
  isRecurring     Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("expense_entries")
}

model BudgetPlan {
  id              String    @id @default(uuid())
  userId          String
  totalMonthly    Float
  categories      Json // {category: budget_amount}
  overspendRules  Json? // Alert thresholds
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("budget_plans")
}

// ----------------------------------------------------------------------------
// Bank Accounts
// ----------------------------------------------------------------------------

model BankAccount {
  id              String    @id @default(uuid())
  userId          String
  bankName        String
  accountType     String // "SAVINGS", "CURRENT", "FD", "RD"
  accountNumber   String // Encrypted
  ifsc            String?
  holders         Json? // Array of names if joint account
  openingBalance  Float?
  currentBalance  Float?
  status          String    @default("ACTIVE") // "ACTIVE", "DORMANT", "CLOSED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("bank_accounts")
}

// ----------------------------------------------------------------------------
// Investments
// ----------------------------------------------------------------------------

model InvestmentHolding {
  id              String    @id @default(uuid())
  userId          String
  type            String // "MUTUAL_FUND", "STOCKS", "BONDS", "PPF", "NPS", "GOLD", "CRYPTO"
  name            String?
  investedAmount  Float
  currentValue    Float?
  maturityDate    DateTime? @db.Date
  lockInPeriod    Int? // Months
  riskLevel       String? // "LOW", "MEDIUM", "HIGH"
  linkedGoalId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            Goal?     @relation(fields: [linkedGoalId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("investment_holdings")
}

// ----------------------------------------------------------------------------
// Insurance
// ----------------------------------------------------------------------------

model InsurancePolicy {
  id              String    @id @default(uuid())
  userId          String
  type            String // "LIFE", "HEALTH", "VEHICLE", "HOME", "TRAVEL"
  policyNumber    String
  insurerName     String?
  sumAssured      Float
  premium         Float
  premiumFrequency String   @default("ANNUAL") // "MONTHLY", "QUARTERLY", "ANNUAL"
  dueDate         DateTime  @db.Date
  maturityDate    DateTime? @db.Date
  nomineeId       String? // FamilyMember ID
  agentContact    String?
  status          String    @default("ACTIVE") // "ACTIVE", "LAPSED", "MATURED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverage        InsuranceCoverage[]

  @@index([userId])
  @@index([type])
  @@index([dueDate])
  @@map("insurance_policies")
}

model InsuranceCoverage {
  id              String    @id @default(uuid())
  policyId        String
  memberId        String // FamilyMember ID

  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  member          FamilyMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([policyId, memberId])
  @@map("insurance_coverage")
}

// ----------------------------------------------------------------------------
// Loans & Liabilities
// ----------------------------------------------------------------------------

model LoanAccount {
  id              String    @id @default(uuid())
  userId          String
  type            String // "HOME", "PERSONAL", "VEHICLE", "EDUCATION", "BUSINESS"
  lenderName      String?
  principal       Float
  outstandingAmount Float
  emi             Float
  interestRate    Float
  tenure          Int // Months
  startDate       DateTime  @db.Date
  endDate         DateTime? @db.Date
  linkedPropertyId String? // If home loan
  status          String    @default("ACTIVE") // "ACTIVE", "CLOSED", "FORECLOSED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("loan_accounts")
}

// ----------------------------------------------------------------------------
// Property
// ----------------------------------------------------------------------------

model PropertyAsset {
  id              String    @id @default(uuid())
  userId          String
  type            String // "RESIDENTIAL", "COMMERCIAL", "LAND"
  address         String?
  purchaseDate    DateTime? @db.Date
  purchaseAmount  Float?
  currentValue    Float?
  ownContribution Float?
  linkedLoanId    String?
  rentalIncome    Float?
  annualCosts     Float?
  propertyTax     Float?
  vacancyMonths   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("property_assets")
}

// ----------------------------------------------------------------------------
// Subscriptions
// ----------------------------------------------------------------------------

model Subscription {
  id              String    @id @default(uuid())
  userId          String
  name            String
  category        String? // "STREAMING", "SOFTWARE", "GYM", "SIM", "OTHER"
  amount          Float
  renewalDate     DateTime  @db.Date
  lastUsedDate    DateTime? @db.Date
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([renewalDate])
  @@map("subscriptions")
}

// ----------------------------------------------------------------------------
// Goals
// ----------------------------------------------------------------------------

model Goal {
  id              String    @id @default(uuid())
  userId          String
  name            String
  targetAmount    Float
  targetDate      DateTime  @db.Date
  currentSaved    Float     @default(0)
  requiredMonthlySavings Float?
  priority        String    @default("MEDIUM") // "LOW", "MEDIUM", "HIGH"
  status          String    @default("IN_PROGRESS") // "IN_PROGRESS", "ACHIEVED", "PAUSED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  investments     InvestmentHolding[]

  @@index([userId])
  @@index([status])
  @@map("goals")
}

// ----------------------------------------------------------------------------
// Nominee & Will
// ----------------------------------------------------------------------------

model NomineeMapping {
  id              String    @id @default(uuid())
  userId          String
  assetRef        String // "insurance_policy_xyz", "property_abc", "investment_123"
  assetType       String // "INSURANCE", "PROPERTY", "INVESTMENT", "BANK"
  nomineeId       String // FamilyMember ID
  sharePercent    Float     @default(100)
  proofDocLinked  Boolean   @default(false)
  confirmed       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nominee         FamilyMember @relation(fields: [nomineeId], references: [id])

  @@index([userId])
  @@index([assetType])
  @@map("nominee_mapping")
}

model WillStatus {
  id              String    @id @default(uuid())
  userId          String    @unique
  existsFlag      Boolean   @default(false)
  location        String?
  executorName    String?
  executorContact String?
  instructions    String?
  lastReviewDate  DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("will_status")
}

// ----------------------------------------------------------------------------
// Asset Inventory (Non-Financial)
// ----------------------------------------------------------------------------

model AssetInventory {
  id              String    @id @default(uuid())
  userId          String
  itemType        String // "JEWELRY", "ELECTRONICS", "VEHICLE", "ART", "OTHER"
  description     String
  purchaseValue   Float?
  currentValue    Float?
  ownerId         String? // FamilyMember ID if applicable
  insuredFlag     Boolean   @default(false)
  linkedPolicyId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemType])
  @@map("asset_inventory")
}

// ----------------------------------------------------------------------------
// Document Vault
// ----------------------------------------------------------------------------

model DocumentMeta {
  id              String    @id @default(uuid())
  userId          String
  docType         String // "INSURANCE", "IDENTITY", "PROPERTY", "LOAN", "INVESTMENT", "WILL", "OTHER"
  linkedPersonId  String? // FamilyMember ID or userId
  linkedEntityId  String? // Policy ID, Property ID, etc.
  fileName        String
  fileHash        String? // For duplicate detection
  localPathRef    String? // Path on user's device (not stored by default)
  cloudBackupConsent Boolean @default(false)
  cloudStorageUrl String? // If cloud backup enabled
  expiryDate      DateTime? @db.Date
  versionTag      String?
  versionHistory  Json? // Array of previous versions
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([docType])
  @@index([expiryDate])
  @@map("document_meta")
}

// ----------------------------------------------------------------------------
// Reminders
// ----------------------------------------------------------------------------

model Reminder {
  id              String    @id @default(uuid())
  userId          String
  type            String // "INSURANCE_RENEWAL", "EMI_DUE", "SUBSCRIPTION_RENEWAL", "GOAL_MILESTONE", "DOC_EXPIRY"
  targetDate      DateTime  @db.Date
  leadTime        Int       @default(7) // Days before target to send reminder
  channel         String    @default("IN_APP") // "IN_APP", "EMAIL", "PUSH", "WHATSAPP"
  priority        String    @default("MEDIUM")
  linkedEntityId  String? // Policy ID, Loan ID, etc.
  message         String?
  sentAt          DateTime?
  status          String    @default("PENDING") // "PENDING", "SENT", "DISMISSED", "SNOOZED"
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetDate])
  @@index([status])
  @@map("reminders")
}

// ----------------------------------------------------------------------------
// Progress Tracking
// ----------------------------------------------------------------------------

model UserModuleProgress {
  id              String    @id @default(uuid())
  userId          String
  moduleId        String
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @default("IN_PROGRESS") // "LOCKED", "IN_PROGRESS", "COMPLETED"

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module          Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@map("user_module_progress")
}

model UserChapterProgress {
  id              String    @id @default(uuid())
  userId          String
  submoduleId     String
  tutorialsWatched Json? // Array of tutorial IDs
  gameStartedAt   DateTime?
  gameCompletedAt DateTime?
  sealConfirmedAt DateTime?
  status          String    @default("LOCKED") // "LOCKED", "IN_PROGRESS", "COMPLETED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  submodule       Submodule @relation(fields: [submoduleId], references: [id], onDelete: Cascade)

  @@unique([userId, submoduleId])
  @@index([userId])
  @@index([submoduleId])
  @@map("user_chapter_progress")
}

model GameRun {
  id              String    @id @default(uuid())
  userId          String
  submoduleId     String
  gameTemplate    String // "FORT_DEFENSE", "MANDALA_LINK", etc.
  attemptNumber   Int       @default(1)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  pointsEarned    Int       @default(0)
  status          String    @default("IN_PROGRESS") // "IN_PROGRESS", "COMPLETED", "ABANDONED"

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([submoduleId])
  @@map("game_runs")
}

// ----------------------------------------------------------------------------
// Gamification
// ----------------------------------------------------------------------------

model GamificationState {
  id              String    @id @default(uuid())
  userId          String    @unique
  totalPoints     Int       @default(0)
  badgesEarned    Json? // Array of badge codes
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  rank            String    @default("BEGINNER")
  lastActivityDate DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gamification_state")
}

// ----------------------------------------------------------------------------
// Rajya Stability Index
// ----------------------------------------------------------------------------

model RajyaScore {
  id              String    @id @default(uuid())
  userId          String    @unique
  overallScore    Float
  rank            String // "STABLE", "BALANCED", "VULNERABLE", "AT_RISK"
  rakshaScore     Float? // Insurance zone
  durgScore       Float? // Emergency readiness
  rinScore        Float? // Loan burden
  vyayaScore      Float? // Expense discipline
  mitraScore      Float? // Nominee/legacy
  koshScore       Float? // Income/wealth
  goalsScore      Float? // Goal progress
  riskFlags       Json? // Array of risk warnings
  nextActions     Json? // Array of recommended actions
  calculatedAt    DateTime  @default(now())
  previousScore   Float?
  trend           String? // "IMPROVING", "STABLE", "DECLINING"

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rank])
  @@map("rajya_scores")
}

// ----------------------------------------------------------------------------
// Activity Tracking
// ----------------------------------------------------------------------------

model ActivityEvent {
  id              String    @id @default(uuid())
  userId          String
  eventType       String // "LOGIN", "COMPLETED_CHAPTER", "UPLOADED_DOC", "EARNED_BADGE", "COMPLETED_MODULE"
  eventData       Json?
  deviceType      String?
  timestamp       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
  @@map("activity_events")
}

// ============================================================================
// SECTION 3: ANALYTICS AGGREGATES (Pre-computed for performance)
// ============================================================================

model DailyAnalytics {
  id              String    @id @default(uuid())
  date            DateTime  @unique @db.Date
  newRegistrations Int      @default(0)
  activeUsers     Int       @default(0)
  dau             Int       @default(0)
  sessionsTotal   Int       @default(0)
  avgSessionDuration Float?
  modulesCompleted Int      @default(0)
  chaptersCompleted Int     @default(0)
  docsUploaded    Int       @default(0)
  supportTicketsCreated Int @default(0)
  calculatedAt    DateTime  @default(now())

  @@index([date])
  @@map("daily_analytics")
}

model WeeklyAnalytics {
  id              String    @id @default(uuid())
  weekStart       DateTime  @db.Date
  weekEnd         DateTime  @db.Date
  wau             Int       @default(0)
  retention7Day   Float?
  retention14Day  Float?
  retention30Day  Float?
  topModule       String?
  topDropOffPoint String?
  calculatedAt    DateTime  @default(now())

  @@unique([weekStart, weekEnd])
  @@index([weekStart])
  @@map("weekly_analytics")
}

model MonthlyAnalytics {
  id              String    @id @default(uuid())
  month           DateTime  @db.Date
  mau             Int       @default(0)
  retention30Day  Float?
  retention60Day  Float?
  retention90Day  Float?
  avgStabilityScore Float?
  productHealthScore Float?
  calculatedAt    DateTime  @default(now())

  @@unique([month])
  @@index([month])
  @@map("monthly_analytics")
}

// ============================================================================
// SECTION 24: CONTACT & SUPPORT
// ============================================================================

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  status    String   @default("UNREAD") // UNREAD, READ, RESPONDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

